rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isValidBooking(data) {
      return data.keys().hasAll(['serviceId', 'date', 'time', 'customerName', 'customerEmail', 'customerPhone', 'address']) &&
             data.customerName is string && data.customerName.size() > 0 &&
             data.customerEmail is string && data.customerEmail.matches('^[^@]+@[^@]+\\.[^@]+$') &&
             data.customerPhone is string && data.customerPhone.size() >= 8;
    }

    // Bookings: Anyone can create a booking (public funnel)
    // Only admins can read/list/update/delete
    match /bookings/{bookingId} {
      allow create: if isValidBooking(request.resource.data);
      allow read, update, delete: if isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "boticaspa@gmail.com");
    }

    // Services: Publicly readable, only admins can write
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "boticaspa@gmail.com");
    }

    // Users: Private data
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}

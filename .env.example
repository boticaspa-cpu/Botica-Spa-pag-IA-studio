# ANTHROPIC_API_KEY: Required for the Tina AI assistant (Claude Haiku).
# Obtén tu clave en https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# GEMINI_API_KEY: Ya no se usa — reemplazado por Claude Haiku
# GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP Configuration for Email Confirmations
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Mercado Pago — obtén tus credenciales en https://www.mercadopago.com.mx/developers
# Usa credenciales de "Prueba" (TEST-...) para sandbox, y las de "Producción" para live
MP_ACCESS_TOKEN=TEST-your-access-token-here

# Google Maps — opcional, activa el autocompletado de direcciones
# Obtén tu clave en https://console.cloud.google.com → habilita "Places API" y "Maps JavaScript API"
VITE_GOOGLE_MAPS_KEY=your-google-maps-key-here

# WhatsApp Cloud API (Meta Business) — opcional
# Obtener en: business.facebook.com → Tu app → WhatsApp → Configuración de API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Clave admin para proteger GET/DELETE /api/reservas
ADMIN_API_KEY=your-secret-admin-key-here
